[MESSAGES CONTROL]
# Suppress false positives for protobuf-generated C extension members
# (pylint cannot introspect these at analysis time).
# Regex matches attribute names that are dynamically generated by protobuf.
generated-members=google\.protobuf\..+,ListToolsRequest,ListToolsResponse,CallToolRequest,CallToolResponse,Tool,TextContent,ImageContent

# Teardown boilerplate in test files is intentionally duplicated.
disable=duplicate-code
